{
  "version": 1,
  "name": "trend-paper-candidate",
  "dataset": {
    "id": "binance-1000d-50coins",
    "path": "data/historical_prices/1000d_50coins.json"
  },
  "coins": ["BTC", "ETH"],
  "strategy": {
    "name": "trend",
    "parameters": {
      "timeframe": "1d",
      "min_score": 4,
      "atr_trailing_enabled": false,
      "failure_exit_enabled": false
    }
  },
  "portfolio": {
    "initial_capital": 1000.0,
    "leverage": 3.0,
    "risk_pct": 0.05,
    "max_positions": 2
  },
  "costs": {
    "fee_bps": 4.5,
    "slippage_bps": 2.0
  },
  "evaluation": {
    "baseline": "experiments/trend_baseline.json",
    "windows": [120, 180, 240],
    "universes": [["BTC"], ["BTC", "ETH"]],
    "min_trades": 5,
    "min_eligible_comparisons": 3,
    "require_majority": true
  },
  "target_environment": "paper"
}

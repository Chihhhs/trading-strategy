  "coins": ["BTC", "ETH", "BNB", "NEO", "LTC", "QTUM", "ADA", "XRP", "TUSD", "IOTA", "XLM", "ONT", "TRX", "ETC", "ICX", "VET", "USDC", "LINK", "ONG", "HOT", "ZIL", "ZRX", "FET", "BAT", "ZEC", "IOST", "CELR", "DASH", "THETA", "ENJ", "ATOM", "TFUEL", "ONE", "ALGO", "DOGE", "DUSK", "ANKR", "WIN", "MTL", "CVC", "CHZ", "BAND", "XTZ", "RVN", "HBAR", "STX", "KAVA", "ARPA", "IOTX", "RLC"],
